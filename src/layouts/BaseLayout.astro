---
import SEOHead from '../components/SEOHead.astro';
import WebsiteSchema from '../components/WebsiteSchema.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  author?: string;
  noindex?: boolean;
  showSchema?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  type = 'website',
  pubDate,
  author,
  noindex,
  showSchema = true,
} = Astro.props;

// GA4 Measurement ID — replace with your actual ID from Google Analytics
const GA_ID = 'G-XXXXXXXXXX';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      imageAlt={imageAlt}
      type={type}
      pubDate={pubDate}
      author={author}
      noindex={noindex}
    />

    {showSchema && <WebsiteSchema />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="ArtOnly RSS Feed" href="/rss.xml" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet" />

    <!-- Google Analytics 4 via Partytown (off main thread) -->
    <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body class="bg-bone text-ink font-sans antialiased">

    <!-- Header -->
    <header class="border-b border-ink/10 sticky top-0 bg-bone/95 backdrop-blur-sm z-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
        <a href="/" class="font-serif text-xl font-bold tracking-tight hover:text-accent transition-colors">
          ArtOnly
        </a>
        <nav class="flex items-center gap-6 text-sm font-medium">
          <a href="/art" class="hover:text-accent transition-colors uppercase tracking-widest text-xs">Art</a>
          <a href="/music" class="hover:text-accent transition-colors uppercase tracking-widest text-xs">Music</a>
          <a href="/culture" class="hover:text-accent transition-colors uppercase tracking-widest text-xs">Culture</a>
          <a href="/about" class="hover:text-accent transition-colors uppercase tracking-widest text-xs">About</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-ink/10 mt-20 py-10">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ash">
        <p>&copy; {new Date().getFullYear()} ArtOnly. All rights reserved.</p>
        <div class="flex items-center gap-6">
          <a href="/rss.xml" class="hover:text-ink transition-colors">RSS</a>
          <a href="mailto:hello@artonly.io" class="hover:text-ink transition-colors">Contact</a>
          <a href="/about" class="hover:text-ink transition-colors">About</a>
        </div>
      </div>
    </footer>

  </body>
</html>

---
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ArtOnly',
  url: 'https://artonly.io',
  description: 'Independent coverage of art, music, and culture.',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://artonly.io/search?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ArtOnly',
  url: 'https://artonly.io',
  logo: 'https://artonly.io/logo.png',
  sameAs: [],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hello@artonly.io',
    contactType: 'editorial',
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

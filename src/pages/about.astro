---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — ArtOnly"
  description="ArtOnly is an independent publication covering art, music, and culture."
  canonical="https://artonly.io/about"
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
    <div class="mb-10">
      <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-2">About</p>
      <h1 class="font-serif text-4xl font-bold mb-6">ArtOnly</h1>
      <div class="prose prose-lg max-w-none prose-headings:font-serif prose-a:text-accent">
        <p>
          ArtOnly is an independent publication dedicated to art, music, and culture.
          We cover exhibitions, albums, films, and the ideas shaping contemporary creative life —
          with honest criticism and genuine curiosity.
        </p>
        <p>
          We believe culture criticism matters. The work of artists, musicians, and thinkers
          deserves careful attention — not algorithmic ranking or affiliate-link listicles.
        </p>
        <h2>Contact</h2>
        <p>
          Pitches, press releases, and correspondence: <a href="mailto:hello@artonly.io">hello@artonly.io</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

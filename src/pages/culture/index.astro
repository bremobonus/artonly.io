---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'culture'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Culture — ArtOnly"
  description="Film, fashion, literature, and the currents shaping contemporary culture."
  canonical="https://artonly.io/culture"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-10 border-b border-ink/10 pb-8">
      <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-2">Section</p>
      <h1 class="font-serif text-4xl font-bold">Culture</h1>
      <p class="text-ash mt-2">Film, fashion, literature, and the currents shaping contemporary culture.</p>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      {posts.map(post => (
        <a href={`/${post.slug}`} class="group">
          {post.data.image && (
            <div class="aspect-video overflow-hidden bg-ink/5 mb-4">
              <img
                src={post.data.image}
                alt={post.data.imageAlt || post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          )}
          <div class="text-xs uppercase tracking-widest text-ash mb-2">{formatDate(post.data.pubDate)}</div>
          <h2 class="font-serif font-bold text-lg leading-snug group-hover:text-accent transition-colors">
            {post.data.title}
          </h2>
          <p class="text-ash text-sm mt-2 leading-relaxed line-clamp-2">{post.data.description}</p>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-ash text-center py-20">No culture posts yet.</p>
    )}
  </div>
</BaseLayout>

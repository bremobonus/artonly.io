---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — ArtOnly" description="Page not found." noindex={true}>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-32 text-center">
    <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-4">404</p>
    <h1 class="font-serif text-4xl font-bold mb-4">Page Not Found</h1>
    <p class="text-ash text-lg mb-8">The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class="text-xs uppercase tracking-widest font-semibold text-ink border-b border-ink pb-0.5 hover:text-accent hover:border-accent transition-colors">
      Back to Home
    </a>
  </div>
</BaseLayout>
